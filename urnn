#!/bin/sh
# wrapper script for urnn scripts and functions

usage()
{
  echo "usage: $0 [retrain|regen|refresh|colors|colors.sh] (file) (file)"
  echo "       retrain               retrain urnn with the current dataset"
  echo "       regen                 regenerate ALL urnn data from inputs (HEAVY operation)"
  echo "       refresh               repopulate urnn.data file from dataset(after an add, for example)"
  echo "       colors (img)          generate xresources to STDOUT using current training result"
  echo "       colors.sh (img)       generate shell variables to STDOUT using current training result"
  echo "       add (img) (Xres)      generate and add urnn data to current dataset(for quickly testing)"
  echo "       addinput (img) (Xres) generate and add urnn data to dataset, and add files to input/staging"
  exit 1
}

setup()
{
  [ -f network/urnn_train ] && return 0
  make --silent -C network
  make --silent -C colors/sin_colors
}

retrain()
{
  cd network
  ./urnn_train urnn.data urnn.trained
}

regen()
{
  urnnputs

  # clear out the current dataset.
  rm dataset/*.data

  # Make new dataset from input/data.
  # In original code, regen requires 'extracter.pl' which pulls data from
  # submodule 'inputs' and builds the dataset locally.
  # Since we've removed the Perl script and the base dataset is part of the repo,
  # 'regen' without explicit access to 'inputs/data' would just delete the local dataset.
  # We block 'regen' if the inputs source doesn't exist, to prevent breaking
  # local setups without an internet connection to the input submodule.
  if [ ! -d inputs/data ]; then
    echo "Regen requires inputs/data submodule which is not present or configured."
    echo "Skipping regeneration to preserve existing dataset."
    return 1
  fi

  echo "Warning: extracter script needs porting to awk if still in use."
  # cd scripts
  # ./extracter.awk
  # cd ..

  # repopulate urnn.data
  refresh
}

refresh()
{
  cd network

  sets=`find ../dataset/ -name "*.images.data" | wc -l`
  echo "$sets 30 54" > urnn.data
  for file in $(ls ../dataset | sort); do
    (cat ../dataset/$file; echo) >> urnn.data
  done
}

colors_common()
{
  file="$1"
  [ -z "$file" ] && usage
  [ ! -f "$file" ] && echo "ERR: could not find $file" && exit 1

  store="$(mktemp)"

  if [ ! -f "network/urnn.trained" ] || ! head -n 1 "network/urnn.trained" | grep -q "genann"; then
    echo "Warning: Old or missing network weights detected." >&2
    echo "Please run \`urnn retrain\` to train the network since you upgraded to genann and weights have changed." >&2
  fi

  # Get colors using sin_colors, fix them, and convert to values
  raw_colors=$(colors/sin_colors/colors -en 10 "$file" | xargs)
  fixed_colors=$(awk -f scripts/fix_colors.awk $raw_colors)
  echo $fixed_colors | xargs -n1 | awk -v ratio=1 -f scripts/convert_hex_to_val.awk > "$store"

  # Network output
  raw_vals=$(network/urnn_run network/urnn.trained "$store" 2>/dev/null)
  rm "$store"
  echo "$raw_vals"
}

colors()
{
  raw_vals=$(colors_common "$1")
  echo "$raw_vals" | xargs -n3 | awk -v ratio=1 -v show_name=1 -f scripts/convert_val_to_xresources_colors.awk
}

colors_sh()
{
  raw_vals=$(colors_common "$1")
  echo "$raw_vals" | xargs -n3 | awk -v ratio=1 -f scripts/convert_val_to_xresources_colors.awk > /tmp/urnn_raw_colors

  bg=$(sed -n '1p' /tmp/urnn_raw_colors)
  fg=$(sed -n '2p' /tmp/urnn_raw_colors)
  echo "URNN_BACKGROUND=\"$bg\""
  echo "URNN_FOREGROUND=\"$fg\""

  idx=0
  sed '1,2d' /tmp/urnn_raw_colors | while read -r col; do
    echo "URNN_COLOR${idx}=\"$col\""
    idx=$((idx+1))
  done
  rm /tmp/urnn_raw_colors
}

add()
{
  image_file="$file_rel/$1"
  xres_file="$file_rel/$2"
  [ -z "$image_file" ] && usage
  [ -z "$xres_file" ] && usage
  [ ! -f "$image_file" ] && echo "ERR: could not find $image_file" && exit 1

  filename="${USER}_$(date +%s)"

  # Xresources
  awk -f scripts/extract_hex_from_xresources.awk "$xres_file" | awk -v ratio=1 -f scripts/convert_hex_to_val.awk > "dataset/${filename}.resources.data"

  raw_colors=$(colors/sin_colors/colors -en 10 "$image_file" | xargs)
  fixed_colors=$(awk -f scripts/fix_colors.awk $raw_colors)
  echo $fixed_colors | xargs -n1 | awk -v ratio=1 -f scripts/convert_hex_to_val.awk > "dataset/${filename}.images.data"
}

addinput()
{
  add "$1" "$2"
  cp "$image_file" "inputs/staging/${filename}.png"
  cp "$xres_file" "inputs/staging/${filename}.resources"
  echo "Generated by $USER" > "inputs/staging/${filename}.txt"
}

urnnputs()
{
  if [ ! -d inputs/data ]; then
    echo "no input/data directory found, pulling urnnputs."
    git submodule init
    git submodule update
  fi
}

file_rel=$(pwd)
cd $(dirname $([ -L $0  ] && readlink -f $0 || echo $0))

setup
if [ $? -ne 0 ]; then
  echo "Compilation failed."
  exit 1
fi

case $1 in
  retrain|refresh|regen|colors|add|addinput)
    $@ || usage;;
  colors.sh)
    colors_sh "$2" || usage;;
  *)
    usage;;
esac
